RewriteEngine On
RewriteBase /

# Block unwanted bots and scrapers
RewriteCond %{HTTP_USER_AGENT} (MJ12bot|DotBot|AhrefsBot|SemrushBot|PetalBot) [NC]
RewriteRule ^ - [F,L]

# Assets are served directly
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Everything else goes to index.php
RewriteRule ^ index.php [L]
