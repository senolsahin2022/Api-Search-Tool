RewriteEngine On
RewriteBase /

# ============================================
# HTTPS REDIRECT (Cloudflare Flexible SSL)
# ============================================
RewriteCond %{HTTP:X-Forwarded-Proto} !https
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ============================================
# WWW TO NON-WWW REDIRECT
# ============================================
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

# ============================================
# SECURITY HEADERS - MAXIMUM HARDENING
# ============================================
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "DENY"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=(), autoplay=(), fullscreen=(self), display-capture=()"
    Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
    Header set Content-Security-Policy "default-src 'none'; script-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com; img-src 'self' https://pbs.twimg.com https://abs.twimg.com data:; media-src 'self' https://video.twimg.com blob:; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests;"
    Header set X-Permitted-Cross-Domain-Policies "none"
    Header set X-Download-Options "noopen"
    Header set Cross-Origin-Embedder-Policy "unsafe-none"
    Header set Cross-Origin-Opener-Policy "same-origin"
    Header set Cross-Origin-Resource-Policy "same-origin"
    Header always unset X-Powered-By
    Header always unset Server
    Header always unset X-AspNet-Version
    Header always unset X-AspNetMvc-Version
    RequestHeader unset Proxy
</IfModule>

# Disable server signature
ServerSignature Off

# ============================================
# BLOCK MALICIOUS BOTS, SCANNERS & SCRAPERS
# ============================================
RewriteCond %{HTTP_USER_AGENT} (MJ12bot|DotBot|AhrefsBot|SemrushBot|PetalBot|BLEXBot|DataForSeoBot|Bytespider|GPTBot|CCBot|ClaudeBot|anthropic-ai|Sogou|python-requests|python-urllib|Go-http-client|Scrapy|Wget|curl|nikto|sqlmap|nmap|masscan|ZmEu|dirbuster|gobuster|wfuzz|nuclei|httpx|ffuf|feroxbuster|Havij|Nessus|OpenVAS|w3af|Acunetix|AppScan|WebInspect|BurpSuite|Hydra|Medusa|THC|JBoss|Jorgee|Morfeus|Toata|Voila|libwww-perl|lwp-trivial|HTTrack|clshttp|cmsScan|harvest|extract|sucker|grab|siphon|BlackWidow|CopyRightCheck|Bolt|Collector|EmailSiphon|WebLeacher|WebCopier|WebZIP|Teleport|TurnitinBot|Nutch|NetcraftSurveyAgent|Siege|ApacheBench|Pangolin|Xenu|BlinkaCrawler|backlink|spy|track|scan|attack|hack|exploit|inject|payload|pentest|vuln|wp-scan|wpscan|joomscan|droopescan|CMSmap|XSStrike|commix|tplmap) [NC]
RewriteRule ^ - [F,L]

# Block empty User-Agent (Cloudflare health checks exempt)
RewriteCond %{HTTP_USER_AGENT} ^-$
RewriteRule ^ - [F,L]

# ============================================
# BLOCK DANGEROUS HTTP METHODS
# ============================================
RewriteCond %{REQUEST_METHOD} !^(GET|HEAD|POST)$ [NC]
RewriteRule ^ - [F,L]

# ============================================
# BLOCK POST TO NON-ALLOWED PATHS
# ============================================
RewriteCond %{REQUEST_METHOD} ^POST$ [NC]
RewriteCond %{REQUEST_URI} !^/(search|downloader)$ [NC]
RewriteRule ^ - [F,L]

# ============================================
# BLOCK OVERSIZED REQUESTS (>10KB body)
# ============================================
<IfModule mod_rewrite.c>
    RewriteCond %{HTTP:Content-Length} ^[0-9]+$
    RewriteCond %{HTTP:Content-Length} >10240
    RewriteRule ^ - [F,L]
</IfModule>

# ============================================
# BLOCK SUSPICIOUS HEADERS
# ============================================
RewriteCond %{HTTP:X-Forwarded-Host} !^$ [NC]
RewriteCond %{HTTP:X-Forwarded-Host} !^freedom-x\.net$ [NC]
RewriteRule ^ - [F,L]

RewriteCond %{HTTP:X-Original-URL} !^$ [NC]
RewriteRule ^ - [F,L]

RewriteCond %{HTTP:X-Rewrite-URL} !^$ [NC]
RewriteRule ^ - [F,L]

# ============================================
# BLOCK FILE ACCESS - SENSITIVE FILES
# ============================================
<FilesMatch "\.(env|git|svn|htpasswd|htaccess|ini|log|sh|sql|bak|backup|old|orig|dist|config|yml|yaml|toml|lock|json|md|csv|db|sqlite|sqlite3|pem|key|crt|cer|der|p12|pfx|jks|conf|cfg|cnf)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

<FilesMatch "^(composer|package|webpack|gulpfile|Gruntfile|Makefile|Dockerfile|Vagrantfile|\.editorconfig|\.gitignore|\.gitattributes|\.dockerignore|\.browserslistrc|\.babelrc|\.eslintrc|\.prettierrc|tsconfig|phpunit|phpstan|psalm|codeception|behat|Gemfile|Rakefile|Procfile|Pipfile|requirements|setup\.py|tox\.ini)">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
</FilesMatch>

# ============================================
# PROTECT DIRECTORIES & SERVER CONFIG
# ============================================
Options -Indexes -ExecCGI -Includes -MultiViews +FollowSymLinks
<IfModule mod_autoindex.c>
    IndexIgnore *
</IfModule>

# Block access to includes, pages, scripts directories directly
RewriteRule ^(includes|pages|scripts)/ - [F,L]

# ============================================
# ALLOWED URL PATTERNS (WHITELIST)
# ============================================

# Allow assets (css, js, images, fonts + root level assets)
RewriteCond %{REQUEST_URI} \.(css|js|svg|png|jpg|jpeg|gif|webp|ico|woff|woff2|ttf|eot|otf)$ [NC]
RewriteCond %{REQUEST_URI} ^/assets/ [NC]
RewriteRule ^ - [L]

# Block non-allowed file types in assets
RewriteCond %{REQUEST_URI} ^/assets/ [NC]
RewriteCond %{REQUEST_URI} !\.(css|js|svg|png|jpg|jpeg|gif|webp|ico|woff|woff2|ttf|eot|otf)$ [NC]
RewriteRule ^ - [F,L]

# Allow favicon and standard files
RewriteRule ^(favicon\.ico|favicon\.svg|apple-touch-icon\.png)$ - [L]

# Allow robots.txt and sitemap.xml
RewriteRule ^(robots\.txt|sitemap\.xml)$ index.php [L]

# Allow .well-known (for SSL verification etc.)
RewriteRule ^\.well-known/ - [L]

# Allow homepage
RewriteRule ^$ index.php [L]

# Allow static pages (exact match)
RewriteRule ^(search|downloader|widget|video-proxy)$ index.php [L]

# Allow widget API subpath
RewriteRule ^widget/api$ index.php [L]

# Allow /user/{safe-username} - alphanumeric + underscore only, max 30 chars
RewriteRule ^user/[A-Za-z0-9_]{1,30}$ index.php [L]

# Allow /hashtag/{tag}
RewriteRule ^hashtag/.{1,100}$ index.php [L]

# Allow /status/{digits only} - tweet IDs
RewriteRule ^status/[0-9]{1,25}$ index.php [L]

# ============================================
# SECURITY - BLOCK ALL ATTACK VECTORS
# ============================================

# Block WordPress / CMS attack paths
RewriteCond %{REQUEST_URI} (wp-admin|wp-login|wp-content|wp-includes|wp-config|wp-cron|wp-json|wp-signup|xmlrpc|administrator|admin\.php|admin/|login\.php|phpmyadmin|pma|myadmin|adminer|filemanager|cpanel|webmail|plesk|directadmin|ispconfig|webmin|ckeditor|fckeditor|elfinder|tinymce|uploadify|ckfinder|kindeditor|ueditor|joomla|drupal|magento|prestashop|opencart|typo3|concrete5|silverstripe|craft|laravel|symfony) [NC]
RewriteRule ^ - [F,L]

# Block hack/scan paths & sensitive files
RewriteCond %{REQUEST_URI} (\.git|\.svn|\.hg|\.bzr|\.env|\.htpasswd|\.htaccess|\.DS_Store|Thumbs\.db|desktop\.ini|cgi-bin|etc/passwd|etc/shadow|etc/hosts|proc/self|proc/version|boot\.ini|win\.ini|\.aws|\.ssh|\.docker|\.kube|\.npmrc|\.bash_history|\.bash_profile|\.bashrc|\.zshrc|\.mysql_history|\.psql_history|\.viminfo|\.netrc|id_rsa|id_dsa|id_ecdsa|id_ed25519|authorized_keys|known_hosts|\.gnupg|\.pgp|wp-config\.php|configuration\.php|config\.php|settings\.php|LocalSettings\.php|parameters\.yml|database\.yml|secrets\.yml|credentials\.yml) [NC]
RewriteRule ^ - [F,L]

# Block common shell/backdoor/webshell paths
RewriteCond %{REQUEST_URI} (c99shell|c100shell|r57shell|r99shell|webshell|b374k|wso\.php|alfa\.php|FilesMan|phpspy|phpkit|locus7shell|storm7shell|cgitelnet|indoxploit|sadrazam|b4tm4n|mini_shell|p0wny-shell|backdoor\.php|trojan\.php|rootkit\.php) [NC]
RewriteRule ^ - [F,L]

# Block server info/debug endpoints
RewriteCond %{REQUEST_URI} (phpinfo|php-info|test\.php|info\.php|debug|trace|server-status|server-info|balancer-manager|jmx-console|web-console|healthcheck\.php|apc\.php|opcache|memcache|redis|mongo|elastic) [NC]
RewriteRule ^ - [F,L]

# Block API/dev tool paths
RewriteCond %{REQUEST_URI} (api/v[0-9]|graphql|swagger|openapi|api-docs|actuator|metrics|prometheus|grafana|kibana|solr|jenkins|hudson|bamboo|travis|circleci|gitlab|bitbucket|\.vscode|\.idea) [NC]
RewriteRule ^ - [F,L]

# Block PHP file access (only index.php allowed)
RewriteCond %{REQUEST_URI} \.(php|phtml|php3|php4|php5|php7|php8|pht|phar|phps|inc|tpl|module|install|engine|cgi|pl|py|rb|jsp|jspx|asp|aspx|ascx|ashx|asmx|axd|cshtml|vbhtml|sh|bash|zsh|ksh|cmd|bat|ps1|psm1|psd1)$ [NC]
RewriteCond %{REQUEST_URI} !^/index\.php$ [NC]
RewriteRule ^ - [F,L]

# Block directory traversal (all encodings)
RewriteCond %{THE_REQUEST} (\.\./|\.\.\\|%2e%2e|%252e%252e|%c0%ae|%c1%1c|\.%00\.|%25%32%65) [NC]
RewriteRule ^ - [F,L]

# Block null bytes (all encodings)
RewriteCond %{THE_REQUEST} (%00|%0d|%0a|\\x00|\\x0d|\\x0a|%25%30%30) [NC]
RewriteRule ^ - [F,L]

# Block HTTP response splitting
RewriteCond %{THE_REQUEST} (%0d%0a|%0D%0A|\\r\\n) [NC]
RewriteRule ^ - [F,L]

# Block SQL injection in URI and query strings (comprehensive)
RewriteCond %{REQUEST_URI} (union[\s\+]*(?:all[\s\+]*)?select|insert[\s\+]*into|drop[\s\+]*(?:table|database|schema)|delete[\s\+]*from|update[\s\+]*set|alter[\s\+]*table|create[\s\+]*(?:table|database|schema|index|view|procedure|function|trigger)|truncate[\s\+]*table|exec(?:ute)?|xp_|sp_|0x[0-9a-f]{8,}|base64_decode|base64_encode|concat\s*\(|char\s*\(|chr\s*\(|ascii\s*\(|ord\s*\(|hex\s*\(|unhex\s*\(|substring\s*\(|substr\s*\(|mid\s*\(|information_schema|benchmark\s*\(|sleep\s*\(|waitfor|delay|load_file|outfile|dumpfile|into[\s\+]*(?:file|outfile|dumpfile)|group[\s\+]*by|order[\s\+]*by[\s\+]*[0-9]|having[\s\+]*[0-9]|\/\*[\s\S]*?\*\/|--[\s]|#[\s]) [NC]
RewriteRule ^ - [F,L]

RewriteCond %{QUERY_STRING} (union[\s\+]*(?:all[\s\+]*)?select|insert[\s\+]*into|drop[\s\+]*(?:table|database|schema)|delete[\s\+]*from|update[\s\+]*set|alter[\s\+]*table|create[\s\+]*(?:table|database)|truncate|exec(?:ute)?|xp_|sp_|0x[0-9a-f]{8,}|base64_decode|base64_encode|concat\s*\(|char\s*\(|chr\s*\(|information_schema|benchmark\s*\(|sleep\s*\(|waitfor|delay|load_file|outfile|dumpfile|into[\s\+]*file|\/\*.*?\*\/|--[\s]|#[\s]) [NC]
RewriteRule ^ - [F,L]

# Block XSS attacks (URI + query string, comprehensive)
RewriteCond %{REQUEST_URI} (<script|%3Cscript|%3cscript|javascript:|vbscript:|livescript:|expression\(|url\(|@import|onload\s*=|onerror\s*=|onclick\s*=|onmouseover\s*=|onfocus\s*=|onblur\s*=|onsubmit\s*=|onkeyup\s*=|onkeydown\s*=|onkeypress\s*=|onchange\s*=|onmouseout\s*=|ondblclick\s*=|onresize\s*=|onscroll\s*=|onunload\s*=|onbeforeunload\s*=|oninput\s*=|onanimation|ontransition|onpointer|ondrag|onwheel|ontoggle|alert\s*\(|prompt\s*\(|confirm\s*\(|document\.cookie|document\.write|document\.domain|window\.location|window\.open|\.innerHTML|\.outerHTML|\.insertAdjacentHTML|eval\s*\(|setTimeout\s*\(|setInterval\s*\(|Function\s*\(|fromCharCode) [NC]
RewriteRule ^ - [F,L]

RewriteCond %{QUERY_STRING} (<script|%3Cscript|%3cscript|javascript:|vbscript:|expression\(|onload\s*=|onerror\s*=|onclick\s*=|onmouseover\s*=|onfocus\s*=|onblur\s*=|alert\s*\(|prompt\s*\(|confirm\s*\(|document\.cookie|document\.write|window\.location|eval\s*\(|setTimeout\s*\(|setInterval\s*\(|Function\s*\(|fromCharCode|String\.fromCharCode|atob\s*\(|btoa\s*\() [NC]
RewriteRule ^ - [F,L]

# Block command injection (URI + query string)
RewriteCond %{REQUEST_URI} (;|\||\`|>|<|\$\(|%24\(|\$\{|%24\{|/bin/|/usr/bin/|/sbin/|/usr/sbin/|/etc/|/tmp/|/var/|/dev/|/proc/|/sys/|/opt/) [NC]
RewriteRule ^ - [F,L]

RewriteCond %{QUERY_STRING} (\||\`|>|<|\$\(|%24\(|\$\{|%24\{|/bin/|/usr/bin/|/sbin/|/etc/|/tmp/|/var/|/dev/|/proc/) [NC]
RewriteRule ^ - [F,L]

# Block PHP superglobals & protocol wrappers (exempt video-proxy)
RewriteCond %{REQUEST_URI} !^/video-proxy$ [NC]
RewriteCond %{QUERY_STRING} (mosConfig_|global\[|_REQUEST\[|_GET\[|_POST\[|_COOKIE\[|_FILES\[|_SERVER\[|_ENV\[|_SESSION\[|GLOBALS\[|HTTP_|allow_url_include|allow_url_fopen|auto_prepend_file|auto_append_file|register_globals|safe_mode|open_basedir|disable_functions|php://input|php://filter|php://output|php://fd|php://memory|php://temp|data://|expect://|phar://|zip://|compress\.zlib://|compress\.bzip2://|glob://|ogg://|rar://|zlib://|file://|ftp://|ftps://|ssh2://|dict://|ldap://|gopher://) [NC]
RewriteRule ^ - [F,L]

# Block SSRF attempts in query string
RewriteCond %{QUERY_STRING} (127\.0\.0\.1|localhost|0\.0\.0\.0|169\.254\.|10\.|172\.(?:1[6-9]|2[0-9]|3[01])\.|192\.168\.|::1|0:0:0:0|fc00:|fe80:|metadata\.google|metadata\.azure|instance-data) [NC]
RewriteRule ^ - [F,L]

# Block URL-encoded attack patterns
RewriteCond %{THE_REQUEST} (%27|%22|%60|%24%28|%24%7B) [NC]
RewriteRule ^ - [F,L]

# Block long query strings (>2048 chars = attack)
RewriteCond %{QUERY_STRING} ^.{2049,}$
RewriteRule ^ - [F,L]

# Block long URIs (>1024 chars)
RewriteCond %{REQUEST_URI} ^.{1025,}$
RewriteRule ^ - [F,L]

# ============================================
# RATE LIMITING (via mod_evasive if available)
# ============================================
<IfModule mod_evasive20.c>
    DOSHashTableSize 3097
    DOSPageCount 3
    DOSSiteCount 30
    DOSPageInterval 1
    DOSSiteInterval 1
    DOSBlockingPeriod 900
</IfModule>

# ============================================
# COMPRESSION & CACHING FOR ALLOWED ASSETS
# ============================================
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>

<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 1 hour"
    ExpiresByType application/javascript "access plus 1 hour"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
</IfModule>

# ============================================
# CATCH ALL - DENY EVERYTHING NOT MATCHED
# ============================================
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [L]
